NODE_ENV=development
PORT=3000

# Users DB (read URL = write URL until Phase 13 read replicas)
USERS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/users
USERS_READ_DB_URL=postgresql://app:pwd@postgres:5432/users

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Cron schedules (6-field with seconds — every 5s in dev)
USERS_CRON_EXPR=*/5 * * * * *
NOTIFIER_CRON_EXPR=*/5 * * * * *

# Outbox sweep / claim
OUTBOX_BATCH_SIZE=100
OUTBOX_STUCK_THRESHOLD_MS=300000
