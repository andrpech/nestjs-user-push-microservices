NODE_ENV=development
PORT=3000

# Users DB (read URL = write URL until Phase 13 read replicas)
USERS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/users
USERS_READ_DB_URL=postgresql://app:pwd@postgres:5432/users

# Notifications DB
NOTIFICATIONS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/notifications
NOTIFICATIONS_READ_DB_URL=postgresql://app:pwd@postgres:5432/notifications

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Cron schedules — fast cadence for dev visibility (6-field with seconds)
USERS_CRON_EXPR=*/5 * * * * *
NOTIFIER_CRON_EXPR=*/5 * * * * *

# Outbox sweep / claim — small batch for dev
OUTBOX_BATCH_SIZE=100
OUTBOX_STUCK_THRESHOLD_MS=300000

# Notifier scheduling — small batch + short notification delay so the demo loop is snappy
NOTIFIER_BATCH_SIZE=100
NOTIFICATION_DELAY_MS=10000
RECOVERY_THRESHOLD_MS=300000

# Push delivery — point WEBHOOK_URL at your webhook.site URL before running E2E
WEBHOOK_URL=https://webhook.site/REPLACE-ME
PUSH_HTTP_TIMEOUT_MS=5000
PUSH_MAX_ATTEMPTS=5

# Retry caps (5 inbox redeliveries → DLQ; 5 stuck-recovery redrives → FAILED)
INBOX_MAX_ATTEMPTS=5
MAX_REDRIVES=5
