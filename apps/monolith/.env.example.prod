NODE_ENV=production
PORT=3000

# Users DB (read URL = write URL until Phase 13 read replicas)
USERS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/users
USERS_READ_DB_URL=postgresql://app:pwd@postgres:5432/users

# Notifications DB
NOTIFICATIONS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/notifications
NOTIFICATIONS_READ_DB_URL=postgresql://app:pwd@postgres:5432/notifications

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Cron schedules — slower cadence for production-like load (6-field with seconds)
USERS_CRON_EXPR=*/30 * * * * *
NOTIFIER_CRON_EXPR=*/30 * * * * *

# Outbox sweep / claim — larger batch for throughput
OUTBOX_BATCH_SIZE=500
OUTBOX_STUCK_THRESHOLD_MS=300000

# Notifier scheduling — larger batch + longer notification delay
NOTIFIER_BATCH_SIZE=500
NOTIFICATION_DELAY_MS=30000
RECOVERY_THRESHOLD_MS=300000

# Push delivery — production webhook target
WEBHOOK_URL=https://webhook.site/REPLACE-ME
PUSH_HTTP_TIMEOUT_MS=5000
PUSH_MAX_ATTEMPTS=5

# Retry caps
INBOX_MAX_ATTEMPTS=5
MAX_REDRIVES=5
