datasource db {
  provider = "postgresql"
  url      = env("USERS_WRITE_DB_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

model User {
  id                  String    @id
  name                String
  publishedAt         DateTime? @map("published_at")
  publishingStartedAt DateTime? @map("publishing_started_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@map("users")
}
