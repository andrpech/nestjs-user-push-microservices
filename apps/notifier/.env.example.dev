NODE_ENV=development
PORT=3001

# Notifications DB
NOTIFICATIONS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/notifications
NOTIFICATIONS_READ_DB_URL=postgresql://app:pwd@postgres:5432/notifications

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_MGMT_URL=http://guest:guest@rabbitmq:15672

# Notifier scheduling — small batch + short notification delay so the demo loop is snappy
NOTIFIER_BATCH_SIZE=100
NOTIFICATION_DELAY_MS=10000
RECOVERY_THRESHOLD_MS=300000

# Push delivery — point WEBHOOK_URL at your webhook.site URL before running E2E
WEBHOOK_URL=https://webhook.site/REPLACE-ME
PUSH_HTTP_TIMEOUT_MS=5000
PUSH_MAX_ATTEMPTS=5

# Retry caps
INBOX_MAX_ATTEMPTS=5
MAX_REDRIVES=5

# OpenTelemetry — distributed tracing (phase 10)
OTEL_SERVICE_NAME=notifier
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
