datasource db {
  provider = "postgresql"
  url      = env("NOTIFICATIONS_WRITE_DB_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model Notification {
  id                  String             @id
  type                String
  sourceEventId       String             @map("source_event_id")
  recipient           Json
  params              Json
  channel             String
  scheduledFor        DateTime           @map("scheduled_for")
  status              NotificationStatus @default(PENDING)
  attempts            Int                @default(0)
  processingStartedAt DateTime?          @map("processing_started_at")
  redriveCount        Int                @default(0) @map("redrive_count")
  lastRedrivenAt      DateTime?          @map("last_redriven_at")
  lastError           String?            @map("last_error")
  sentAt              DateTime?          @map("sent_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  history NotificationHistory[]

  @@unique([type, sourceEventId])
  @@map("notifications")
}

model NotificationHistory {
  id             String   @id
  notificationId String   @map("notification_id")
  at             DateTime @default(now())
  eventType      String   @map("event_type")
  payload        Json?

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, at])
  @@map("notification_history")
}
