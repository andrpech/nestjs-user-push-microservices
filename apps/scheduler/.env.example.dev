NODE_ENV=development
PORT=3002

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Cron schedules — fast cadence for dev visibility (6-field with seconds)
USERS_CRON_EXPR=*/5 * * * * *
NOTIFIER_CRON_EXPR=*/5 * * * * *

# OpenTelemetry — distributed tracing (phase 10)
OTEL_SERVICE_NAME=scheduler
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
