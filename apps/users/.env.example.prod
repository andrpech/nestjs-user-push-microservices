NODE_ENV=production
PORT=3000

USERS_WRITE_DB_URL=postgresql://app:pwd@postgres:5432/users
USERS_READ_DB_URL=postgresql://app:pwd@postgres:5432/users

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_MGMT_URL=http://guest:guest@rabbitmq:15672

# Outbox sweep / claim — larger batch for throughput
OUTBOX_BATCH_SIZE=500
OUTBOX_STUCK_THRESHOLD_MS=300000

# OpenTelemetry — distributed tracing
OTEL_SERVICE_NAME=users
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
